<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:name=".YinjieApplication"
        android:usesCleartextTraffic="${yinjieUsesCleartextTraffic}"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <meta-data
            android:name="yinjie.api_base_url"
            android:value="" />
        <meta-data
            android:name="yinjie.socket_base_url"
            android:value="" />
        <meta-data
            android:name="yinjie.environment"
            android:value="${yinjieEnvironment}" />

        <!--
            FCM 在 app 处于 background + 收到 notification 字段时，由系统直接弹通知，
            不进 YinjieFirebaseMessagingService.onMessageReceived（详见 Round 14）。
            没有这条 meta-data，SDK 会回落到「fcm_fallback_notification_channel」
            （IMPORTANCE_DEFAULT、英文 "Miscellaneous" 标签）而不是我们已经创建的
            "yinjie_messages"（IMPORTANCE_HIGH、本地化「隐界消息」）；聊天推送被
            当做营销级提示，重要性、声音、状态栏小图标 tint 全部跟前台/本地推送脱节。
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="yinjie_messages" />

        <!--
            Round 24：FCM SDK 在 app 处于 background 直接走系统通知栏时，
            smallIcon 默认取 launcher icon (mipmap/ic_launcher)。它是彩色 RGBA
            全不透明的 PNG，被 Android 5+ 状态栏强制 mask 成纯白方块，没有
            任何品牌可识别度。这里把 default_notification_icon 指到
            res/drawable/ic_stat_notification（alpha-only 的 Y 字形矢量），
            default_notification_color 用 brand 橙色，跟前台 / 本地推送的
            setSmallIcon + setColor 拉齐，statusBar 上才能看见 Yinjie 的 Y。
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notification" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_accent" />

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"><!--
            Round 36：必须显式声明 adjustResize。capacitor.config.json 里
            Keyboard plugin 配的 "resize": "native" 依赖 manifest 上写明
            adjustResize 才能在键盘弹起时让窗口（连带 WebView 可视区）
            自动缩小，留出键盘高度给输入框。没声明时默认是
            adjustUnspecified，OEM 之间分歧：
              - Samsung One UI 多个版本默认 adjustPan
              - Huawei EMUI / 华为 HarmonyOS App 模式 默认 adjustPan
              - Xiaomi MIUI 部分版本 / 红米早期机型 默认 adjustPan
              - Vivo OriginOS / OPPO ColorOS 部分版本 默认 adjustNothing
            adjustPan / adjustNothing 都是「键盘盖住下半截」，焦点输入框
            如果不在屏幕上半区就被键盘整个遮住，用户**看不到自己在打字**。
            adjustResize 让 Android 把 root container 高度压缩到键盘上边沿，
            WebView 内的 sticky 输入框跟着停在键盘正上方。
        -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <service
            android:name=".YinjieFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

    <!--
        Round 27：Android 11 (API 30) 起 package visibility 默认是「看不见任何
        别的 app」。我们 targetSdk=35，所以 PackageManager.resolveActivity 对
        任何隐式 intent 都会返回 null，哪怕用户手机上有装相机 / 浏览器 / 邮件 /
        电话 app 也认不到。直接症状：
          - YinjieMobileBridgePlugin.captureImage 里
              intent.resolveActivity(getContext().getPackageManager()) == null
            一律成立 → reject("camera app is unavailable")，用户在朋友圈 /
            头像 / 聊天附件「拍照」这条路全断。
          - openExternalUrl 对 tel: / mailto: / sms: 还能借系统隐式 visibility
            走通（这些 scheme 走 Android 自带 dialer/mail/messages），但 https
            链接在没有默认 browser 的设备上 startActivity 会抛
            ActivityNotFoundException，被 catch 静默成 reject。
        声明 <queries> 把我们 plugin 真实用到的 intent 全部列出来，让 Android
        package visibility 给我们 grant 这些目标 app 的可见性。
    -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="*/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="*/*" />
        </intent>
    </queries>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Round 31：声明 <uses-permission android:name="android.permission.CAMERA" />
        但没配对应 <uses-feature>，Google Play 默认把 camera / microphone 当
        硬件必备项—— 没摄像头 / 没麦克风的设备（无前后摄的部分平板、Android TV、
        部分 Chromebook、Android Auto 头单元等）在 Play Store 内被强制过滤掉，
        listing 直接看不到，侧载也会触发兼容性警告。
        captureImage 只是「可选」功能（用户没相机也能用文字 / 文件 picker），
        record_audio 同样是 voice-call / 摇一摇这类可选场景。required="false"
        让 Play Store 把这些设备也涵盖进可安装范围。
    -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
</manifest>
