# Cloud API
CLOUD_JWT_SECRET=
CLOUD_ADMIN_SECRET=
CLOUD_ENFORCE_STRICT_SECRETS=false
CLOUD_DATABASE_PATH=cloud-platform.sqlite
PORT=3001

# Auth
CLOUD_AUTH_TOKEN_TTL=7d
CLOUD_ADMIN_TOKEN_TTL=15m
CLOUD_ADMIN_REFRESH_TOKEN_TTL=7d
CLOUD_JWT_ISSUER=yinjie-cloud-api
CLOUD_CLIENT_JWT_AUDIENCE=yinjie-cloud-client
CLOUD_ADMIN_JWT_AUDIENCE=yinjie-cloud-admin
CLOUD_ADMIN_REFRESH_JWT_AUDIENCE=yinjie-cloud-admin-refresh
CLOUD_CODE_TTL_SECONDS=600
CLOUD_CODE_RESEND_COOLDOWN_SECONDS=60
CLOUD_CODE_RATE_LIMIT_WINDOW_SECONDS=3600
CLOUD_CODE_MAX_PER_WINDOW=5
CLOUD_WAITING_SESSION_SYNC_RETRY_ATTEMPTS=3
CLOUD_WAITING_SESSION_SYNC_RETRY_DELAY_MS=2000
CLOUD_WAITING_SESSION_SYNC_POLL_INTERVAL_MS=1500
CLOUD_WAITING_SESSION_SYNC_LEASE_SECONDS=30

# Email verification (login/register via email code).
# 留空 CLOUD_SMTP_HOST 时验证码会打印到服务端日志（dev mock 模式），凭证就绪后填入即真实发送。
CLOUD_SMTP_HOST=
CLOUD_SMTP_PORT=465
CLOUD_SMTP_SECURE=true
CLOUD_SMTP_USER=
CLOUD_SMTP_PASS=
CLOUD_MAIL_FROM_ADDRESS=
CLOUD_MAIL_FROM_NAME=隐界云
CLOUD_EMAIL_CODE_TTL_SECONDS=600
CLOUD_EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60
CLOUD_EMAIL_CODE_RATE_LIMIT_WINDOW_SECONDS=3600
CLOUD_EMAIL_CODE_MAX_PER_WINDOW=5

# Google OAuth (前端走 Google Identity Services 拿 ID Token，后端用此 client id 验签)。
# 留空时 /cloud/auth/google/verify-id-token 会返回 503，前端按钮不触发；
# 填值后即开通 Google 登录。前后端共用同一个 Web client id；前端通过
# VITE_GOOGLE_OAUTH_CLIENT_ID（apps/app 的构建期 env）注入。
GOOGLE_OAUTH_CLIENT_ID=

# 公网部署必填：world-access serializeAccessSession 把这个值当 resolvedApiBaseUrl
# 返给客户端，把所有租户流量收口到 cloud-api 反代入口 (/cloud/world-api)。
# 反代层按 cloud token 里的 phone 字段路由到该账号的 child process，多租户
# 数据物理隔离。留空时 client 直接拿到 child 的 127.0.0.1:port，公网不可达。
# 例：CLOUD_WORLD_PUBLIC_PROXY_BASE_URL=https://your-public-host/cloud/world-api
CLOUD_WORLD_PUBLIC_PROXY_BASE_URL=

# 已废弃：mock provider 旧的固定 apiBaseUrl 模板。新部署一律走上面的
# CLOUD_WORLD_PUBLIC_PROXY_BASE_URL；mock provider 也由 local-process 取代。
CLOUD_WORLD_API_BASE_URL_TEMPLATE=
