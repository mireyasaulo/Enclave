{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yinjie",
  "version": "0.1.0",
  "identifier": "com.yinjie.runtime",
  "build": {
    "beforeDevCommand": "pnpm --dir ../app dev",
    "beforeBuildCommand": "YINJIE_APP_BUILD_BASE=relative pnpm --dir ../app build",
    "devUrl": "http://127.0.0.1:5180",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Yinjie",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/icon.icns"],
    "externalBin": [],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null,
      "frameworks": [],
      "exceptionDomain": "",
      "resources": [
        "zh-Hans.lproj/InfoPlist.strings",
        "en.lproj/InfoPlist.strings",
        "ja.lproj/InfoPlist.strings",
        "ko.lproj/InfoPlist.strings"
      ]
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": []
    }
  }
}
