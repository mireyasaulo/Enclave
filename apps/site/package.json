{
  "name": "@yinjie/site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/dev-services.mjs start site",
    "dev:raw": "node scripts/sync-assets.mjs && next dev -p 5185",
    "dev:stop": "node ../../scripts/dev-services.mjs stop site",
    "dev:restart": "node ../../scripts/dev-services.mjs restart site",
    "dev:status": "node ../../scripts/dev-services.mjs status site",
    "predev:raw": "node scripts/sync-assets.mjs",
    "prebuild": "node scripts/sync-assets.mjs",
    "build": "next build",
    "start": "next start -p 5185",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@lingui/core": "5.9.5",
    "@lingui/macro": "5.9.5",
    "@lingui/react": "5.9.5",
    "@yinjie/analytics": "workspace:*",
    "@yinjie/i18n": "workspace:*",
    "@yinjie/ui": "workspace:*",
    "lucide-react": "^0.475.0",
    "next": "15.5.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@lingui/loader": "5.9.5",
    "@lingui/swc-plugin": "5.11.0",
    "@tailwindcss/postcss": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "sharp": "^0.34.0",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.9.3"
  }
}
