# iOS shell release env template.
# Copy to `ios-release.env.local` (gitignored) and fill in real values
# before running `pnpm ios:ipa:release` / `pnpm ios:doctor:release` on macOS.

# ---- Runtime config (baked into apps/app/dist/runtime-config.json) ----
export YINJIE_IOS_CORE_API_BASE_URL="https://api.example.yinjie.app"
# Optional: defaults to YINJIE_IOS_CORE_API_BASE_URL when omitted
# export YINJIE_IOS_SOCKET_BASE_URL="https://api.example.yinjie.app"
# cloud-api 多租户反代入口。release build 必须显式设：Capacitor 原生壳的 origin
# 是 capacitor://localhost，没办法像浏览器那样回落到 ${origin}/cloud；不设的话
# worlds 列表 / cloud session refresh / push token 注册等所有 cloud-api 入口
# 都会 fetch null 直接报错。
export YINJIE_IOS_CLOUD_API_BASE_URL="https://cloud.example.yinjie.app"
export YINJIE_IOS_ENVIRONMENT="production"
# Optional: defaults to "Yinjie"
# export YINJIE_IOS_PUBLIC_APP_NAME="Yinjie"

# ---- Xcode build settings (patched into project.pbxproj by ios:configure) ----
# Bundle identifier — must match the App ID registered in your Apple Developer account.
export YINJIE_IOS_BUNDLE_IDENTIFIER="com.yinjie.ios"
# Marketing version (CFBundleShortVersionString) — visible in App Store listing.
export YINJIE_IOS_MARKETING_VERSION="1.0.0"
# Build number (CFBundleVersion) — must be monotonically increasing per upload.
export YINJIE_IOS_BUILD_NUMBER="1"
# Apple Developer team ID (10-character alphanumeric).
export YINJIE_IOS_DEVELOPMENT_TEAM="ABCDE12345"
# CODE_SIGN_STYLE — "Automatic" (Xcode-managed) or "Manual" (explicit profile).
export YINJIE_IOS_CODE_SIGN_STYLE="Automatic"
# Required when CODE_SIGN_STYLE=Manual; provisioning profile name or UUID.
# export YINJIE_IOS_PROVISIONING_PROFILE_SPECIFIER="Yinjie App Store"
# Required when CODE_SIGN_STYLE=Manual; signing identity (e.g. "Apple Distribution: Your Org (TEAMID)").
# export YINJIE_IOS_CODE_SIGN_IDENTITY="Apple Distribution"

# ---- aps-environment (entitlement) ----
# "production" for App Store / TestFlight builds, "development" for dev builds.
export YINJIE_IOS_APS_ENVIRONMENT="production"

# ---- Associated domain (universal links) ----
# Example: applinks:yinjie.app
# export YINJIE_IOS_ASSOCIATED_DOMAIN="applinks:yinjie.app"

# ---- xcodebuild / export options ----
# Xcode scheme name (default: "App", which is the Capacitor template default).
# export YINJIE_IOS_XCODE_SCHEME="App"
# Build configuration (default: "Release").
# export YINJIE_IOS_XCODE_CONFIGURATION="Release"
# Export method — one of: app-store-connect, release-testing, debugging, enterprise.
# Older Xcode (<15) accepts: app-store, ad-hoc, development, enterprise — script
# auto-translates to the legacy names if needed.
export YINJIE_IOS_EXPORT_METHOD="app-store-connect"
# Path (relative to apps/ios-shell or absolute) to a custom ExportOptions.plist.
# When omitted, the build script renders one from the env above into
# build/ios/ExportOptions.plist using xcode-template/ExportOptions.plist.example.
# export YINJIE_IOS_EXPORT_OPTIONS_PLIST="ios-export-options.local.plist"

# ---- App Store Connect upload (optional, only if you want one-shot upload) ----
# When all three are set, build-ios-ipa.mjs runs `xcrun altool --upload-app` after export.
# export YINJIE_IOS_APPSTORE_API_KEY_ID="ABCD123456"
# export YINJIE_IOS_APPSTORE_API_ISSUER_ID="abcd1234-ef56-7890-ab12-cdef34567890"
# export YINJIE_IOS_APPSTORE_API_KEY_PATH="/absolute/path/to/AuthKey_ABCD123456.p8"
