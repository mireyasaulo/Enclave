{
  "name": "@yinjie/ios-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:web": "node ../../scripts/build-mobile-shell-web.mjs",
    "prepare:web": "pnpm run build:web && node ./scripts/inject-runtime-config.mjs",
    "audit": "pnpm run prepare:web && pnpm run doctor",
    "sync": "pnpm run prepare:web && cap sync ios",
    "configure": "node ./scripts/configure-ios-project.mjs",
    "doctor": "node ./scripts/doctor-ios.mjs",
    "doctor:release": "node ./scripts/run-release-command.mjs doctor",
    "open": "cap open ios",
    "archive": "node ./scripts/run-release-command.mjs archive",
    "export": "node ./scripts/run-release-command.mjs export",
    "ipa": "node ./scripts/run-release-command.mjs ipa",
    "ipa:release": "node ./scripts/run-release-command.mjs ipa",
    "typecheck": "node -e \"console.log('iOS shell is scaffolded and currently managed by Capacitor tooling.')\"",
    "lint": "node -e \"console.log('iOS shell linting is handled by Capacitor/Xcode tooling when installed.')\""
  },
  "dependencies": {
    "@capacitor/app": "^7.1.0",
    "@capacitor/core": "^7.1.1",
    "@capacitor/ios": "^7.1.1",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.2",
    "@capacitor/status-bar": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.1.1"
  }
}
