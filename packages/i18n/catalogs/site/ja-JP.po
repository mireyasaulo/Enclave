#: apps/site/src/lib/use-cases-data.ts
msgid "三分钟 docker 部署"
msgstr "3 分で完了する docker デプロイ"
#. js-lingui-explicit-id
#: apps/site/src/lib/use-cases-data.ts
msgid "clone → cp .env → docker compose up，README 顶部就写着这套流程，路人也能跑起来。"
msgstr "clone → cp .env → docker compose up。README の冒頭にそのまま書いてある手順で、初見の人でも動かせます。"
