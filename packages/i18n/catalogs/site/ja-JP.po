msgstr "チャットワークスペース（マルチウィンドウ）"
#. js-lingui-explicit-id
msgid "聊天文件中心"
msgstr "チャットファイル管理"
#. js-lingui-explicit-id
msgid "聊天记录全局搜索"
msgstr "全文チャット検索"
