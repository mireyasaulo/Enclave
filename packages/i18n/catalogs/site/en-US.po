msgstr "Chat file center"
#. js-lingui-explicit-id
msgid "聊天记录全局搜索"
msgstr "Global chat search"
#. js-lingui-explicit-id
msgid "视频号直播伴侣"
msgstr "Channels live companion"
#. js-lingui-explicit-id
msgid "原生托盘 / 锁屏"
msgstr "Native tray & lock screen"
#. js-lingui-explicit-id
msgid "克隆、起 docker、起飞"
msgstr "Clone it, docker compose up, lift off"
#. js-lingui-explicit-id
msgid "完全开源，MIT 许可。无任何外部 SaaS 依赖；一台机器、一条 docker compose up，几分钟就能跑起来。"
msgstr "Fully open source, MIT licensed. No external SaaS dependency — one machine, one docker compose up, ready in minutes."
#. js-lingui-explicit-id
msgid "克隆仓库"
msgstr "Clone the repo"
#. js-lingui-explicit-id
msgid "一键启动"
msgstr "One-line bring-up"
#. js-lingui-explicit-id
msgid "浏览器访问"
msgstr "Open in your browser"
#. js-lingui-explicit-id
