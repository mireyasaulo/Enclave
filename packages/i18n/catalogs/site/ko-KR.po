#. js-lingui-explicit-id
msgid "产品"
msgstr "제품"

#. js-lingui-explicit-id
msgid "核心能力"
msgstr "핵심 기능"

#. js-lingui-explicit-id
msgid "跨端"
msgstr "크로스 플랫폼"

#. js-lingui-explicit-id
msgid "开源自部署"
msgstr "자체 호스팅"

#. js-lingui-explicit-id
msgid "下载"
msgstr "다운로드"

#. js-lingui-explicit-id
msgid "在线试用"
msgstr "온라인 체험"

#. js-lingui-explicit-id
msgid "一个属于你的 AI 虚拟世界。开源、可自部署、跨端可用。"
msgstr "당신만의 AI 가상 세계. 오픈소스, 자체 호스팅 가능, 크로스 플랫폼."

#. js-lingui-explicit-id
msgid "自部署文档"
msgstr "자체 호스팅 가이드"

#. js-lingui-explicit-id
msgid "隐私政策"
msgstr "개인정보 처리방침"

#. js-lingui-explicit-id
msgid "服务条款"
msgstr "서비스 약관"

#. js-lingui-explicit-id
msgid "联系我们"
msgstr "문의하기"

#. js-lingui-explicit-id
msgid "开源 · 可自部署 · 跨端"
msgstr "오픈소스 · 자체 호스팅 · 크로스 플랫폼"

#. js-lingui-explicit-id
msgid "一个属于你的 AI 虚拟世界"
msgstr "당신만의 AI 가상 세계"

#. js-lingui-explicit-id
msgid "在隐界，你不是和一个 chatbot 聊天，而是拥有一个有居民、有时间、有关系的私人世界。它不与现实对立，让现实里的你，多出一种可能。"
msgstr "엔클레이브에서는 챗봇과 대화하는 것이 아니라, 거주민과 시간, 관계를 가진 개인 세계를 가지게 됩니다. 현실과 대립하지 않고, 현실의 당신에게 또 하나의 가능성을 더해 줍니다."

#. js-lingui-explicit-id
msgid "在 GitHub 查看"
msgstr "GitHub에서 보기"

#. js-lingui-explicit-id
msgid "核心闭环演示（动图）"
msgstr "핵심 루프 데모(움짤)"

#. js-lingui-explicit-id
msgid "语言版本"
msgstr "언어"

#. js-lingui-explicit-id
msgid "移动 + 桌面"
msgstr "모바일 + 데스크톱"

#. js-lingui-explicit-id
msgid "开源协议"
msgstr "라이선스"

#. js-lingui-explicit-id
msgid "不是 chatbot，而是一整个生态"
msgstr "챗봇이 아닌, 하나의 생태계"

#. js-lingui-explicit-id
msgid "基于 apps/app 的真实代码盘点而成的能力清单：每一项都已在产品中跑通。"
msgstr "아래의 모든 기능은 apps/app 실제 코드를 기반으로 하며, 모두 제품에 적용되어 있습니다."

#. js-lingui-explicit-id
msgid "聊天与群组"
msgstr "채팅과 그룹"

#. js-lingui-explicit-id
msgid "一对一对话、群聊、线程讨论；消息提醒、强提醒、已读标记一应俱全。"
msgstr "1:1, 그룹, 스레드 대화. 메시지 알림과 강력한 알림, 읽음 표시까지 모두 지원."

#. js-lingui-explicit-id
msgid "AI 数字人通话"
msgstr "AI 디지털 휴먼 통화"

#. js-lingui-explicit-id
msgid "和虚拟角色实时对话——支持 1 对 1、群组、视频与语音多种形式。"
msgstr "가상 캐릭터와 실시간 대화 — 1:1, 그룹, 영상, 음성을 모두 지원합니다."

#. js-lingui-explicit-id
msgid "朋友圈与动态"
msgstr "모먼트와 피드"

#. js-lingui-explicit-id
msgid "发布与浏览朋友动态，AI 角色也会发帖、互动、出现在你的时间线。"
msgstr "개인 피드에 글을 올리고 친구의 소식을 보세요. AI 캐릭터도 게시·반응하며 타임라인에 함께합니다."

#. js-lingui-explicit-id
msgid "小程序工作区"
msgstr "미니 프로그램 워크스페이스"

#. js-lingui-explicit-id
msgid "内嵌的小程序生态，随手打开工具、拓展隐界的能力边界。"
msgstr "내장된 미니 프로그램 생태계로 도구를 열고 엔클레이브의 기능을 확장하세요."

#. js-lingui-explicit-id
msgid "游戏中心"
msgstr "게임 센터"

#. js-lingui-explicit-id
msgid "游戏库与邀请系统，把朋友、AI 角色都拉进同一桌。"
msgstr "게임 라이브러리와 초대 시스템으로 친구와 AI 캐릭터를 한 자리에 모읍니다."

#. js-lingui-explicit-id
msgid "笔记工作区（桌面）"
msgstr "노트 워크스페이스(데스크톱)"

#. js-lingui-explicit-id
msgid "桌面端多窗口笔记，灵感随手记，无缝同步、不受应用边界约束。"
msgstr "데스크톱에서 멀티 윈도우 노트를 작성하고, 영감을 즉시 기록하며 끊김 없이 동기화합니다."

#. js-lingui-explicit-id
msgid "发现与场景社交"
msgstr "발견과 상황별 소셜"

#. js-lingui-explicit-id
msgid "遇见陌生人、按场景社交、浏览世界人物库，遇见新角色与新故事。"
msgstr "낯선 사람을 만나고, 상황별로 소셜하며, 월드 캐릭터 라이브러리에서 새로운 사람과 이야기를 만나세요."

#. js-lingui-explicit-id
msgid "云订阅与权限"
msgstr "클라우드 구독"

#. js-lingui-explicit-id
msgid "灵活的功能分级与支付，按需开启更高级的模型与能力。"
msgstr "유연한 등급과 결제 방식으로 필요할 때 상위 모델과 고급 기능을 활성화합니다."

#. js-lingui-explicit-id
msgid "产品截图"
msgstr "스크린샷"

#. js-lingui-explicit-id
msgid "从入坑到日常使用"
msgstr "온보딩부터 일상 사용까지"

#. js-lingui-explicit-id
msgid "六个核心场景一起看，画面均来自 apps/app 当前真实版本。"
msgstr "6 가지 핵심 화면을 한자리에. 모든 화면은 apps/app 의 최신 빌드에서 캡처되었습니다."

#. js-lingui-explicit-id
msgid "聊天"
msgstr "채팅"

#. js-lingui-explicit-id
msgid "线程化对话与消息提醒"
msgstr "스레드 대화와 알림"

#. js-lingui-explicit-id
msgid "朋友圈"
msgstr "모먼트"

#. js-lingui-explicit-id
msgid "AI 与人共同的时间线"
msgstr "AI 와 사람이 함께 만드는 타임라인"

#. js-lingui-explicit-id
msgid "频道流"
msgstr "채널"

#. js-lingui-explicit-id
msgid "频道、视频号、官方账号"
msgstr "채널, 비디오 계정, 공식 계정"

#. js-lingui-explicit-id
msgid "群组"
msgstr "그룹"

#. js-lingui-explicit-id
msgid "多人对话与角色互动"
msgstr "다자 대화와 캐릭터 상호작용"

#. js-lingui-explicit-id
msgid "入坑引导"
msgstr "온보딩"

#. js-lingui-explicit-id
msgid "新人启动与世界初始化"
msgstr "신규 사용자 시작과 세계 초기 설정"

#. js-lingui-explicit-id
msgid "我的角色"
msgstr "내 캐릭터"

#. js-lingui-explicit-id
msgid "你与 AI 化身的资料卡"
msgstr "당신과 AI 아바타의 프로필 카드"
#. js-lingui-explicit-id
msgid "理念"
msgstr "철학"
#. js-lingui-explicit-id
msgid "一个属于你的世界，从架构开始"
msgstr "당신만의 세계, 설계 단계부터"
#. js-lingui-explicit-id
msgid "隐界不是一个共享的 chatbot 服务，而是一套可独立部署的 AI 社交基础设施。每个实例只为一个人存在。"
msgstr "엔클레이브는 공유 챗봇 서비스가 아니라, 자체 배포 가능한 AI 소셜 인프라입니다. 인스턴스는 사용자당 하나입니다."
#. js-lingui-explicit-id
msgid "一人一世界"
msgstr "한 사람당 하나의 세계"
#. js-lingui-explicit-id
msgid "独立实例架构，数据真正属于用户。隐私不靠承诺，靠架构层保障。"
msgstr "독립 인스턴스 구조. 데이터는 진정으로 당신의 것이며, 개인정보는 약속이 아니라 아키텍처로 보호됩니다."
#. js-lingui-explicit-id
msgid "数据自主"
msgstr "데이터 주권"
#. js-lingui-explicit-id
msgid "全部数据可导入导出，可整包迁移；离开隐界，世界还是你的。"
msgstr "모든 데이터는 가져오기·내보내기 및 통째 이전이 가능합니다. 엔클레이브를 떠나도 세계는 그대로 당신의 것입니다."
#. js-lingui-explicit-id
msgid "AI 平权"
msgstr "AI 평등권"
#. js-lingui-explicit-id
msgid "高质量对话不应被少数平台垄断。隐界让任何人都能拥有自己的 AI 居民。"
msgstr "양질의 대화가 소수 플랫폼의 전유물이어선 안 됩니다. 엔클레이브는 누구나 자신의 AI 주민을 가질 수 있게 합니다."
#. js-lingui-explicit-id
msgid "不取代现实"
msgstr "현실을 대체하지 않는다"
#. js-lingui-explicit-id
msgid "白天有同事、有老板，晚上回到隐界有心理咨询师；它补全你的情感维度，而不是替代真实关系。"
msgstr "낮에는 동료와 상사가 있고, 밤에는 엔클레이브에 상담사가 있습니다. 현실의 관계를 대체하지 않고 감정의 결을 더해 줍니다."
#. js-lingui-explicit-id
msgid "移动随手用，桌面深度用"
msgstr "모바일은 가볍게, 데스크톱은 깊게"
#. js-lingui-explicit-id
msgid "apps/app 是一份 React 19 + TypeScript 代码库，同时跑在 Web、iOS / Android Capacitor 壳、以及 Tauri 桌面壳上。"
msgstr "apps/app 은 하나의 React 19 + TypeScript 코드베이스로, Web, iOS / Android (Capacitor), Tauri 데스크톱 셸에서 모두 동작합니다."
#. js-lingui-explicit-id
msgid "移动端"
msgstr "모바일"
#. js-lingui-explicit-id
msgid "Web / iOS / Android"
msgstr "Web / iOS / Android"
#. js-lingui-explicit-id
msgid "桌面端"
msgstr "데스크톱"
#. js-lingui-explicit-id
msgid "Tauri · Windows / macOS / Linux"
msgstr "Tauri · Windows / macOS / Linux"
#. js-lingui-explicit-id
msgid "聊天工作区（多窗口）"
msgstr "채팅 워크스페이스(멀티 윈도우)"
#. js-lingui-explicit-id
msgid "聊天文件中心"
msgstr "채팅 파일 센터"
#. js-lingui-explicit-id
msgid "聊天记录全局搜索"
msgstr "전역 채팅 검색"
#. js-lingui-explicit-id
msgid "视频号直播伴侣"
msgstr "라이브 컴패니언"
#. js-lingui-explicit-id
msgid "原生托盘 / 锁屏"
msgstr "네이티브 트레이 / 잠금 화면"
#. js-lingui-explicit-id
msgid "克隆、起 docker、起飞"
msgstr "클론, docker compose up, 시작"
#. js-lingui-explicit-id
msgid "完全开源，MIT 许可。无任何外部 SaaS 依赖；一台机器、一条 docker compose up，几分钟就能跑起来。"
msgstr "완전 오픈소스, MIT 라이선스. 외부 SaaS 의존이 없으며, 한 대의 머신에서 docker compose up 으로 몇 분 만에 실행됩니다."
#. js-lingui-explicit-id
msgid "克隆仓库"
msgstr "리포지토리 클론"
#. js-lingui-explicit-id
msgid "一键启动"
msgstr "한 줄로 실행"
#. js-lingui-explicit-id
msgid "浏览器访问"
msgstr "브라우저에서 열기"
#. js-lingui-explicit-id
msgid "查看完整自部署指南"
msgstr "자체 호스팅 가이드 보기"
#. js-lingui-explicit-id
msgid "在 GitHub 上 Star"
msgstr "GitHub 에서 Star"
#. js-lingui-explicit-id
msgid "常见问题"
msgstr "자주 묻는 질문"
#. js-lingui-explicit-id
msgid "FAQ"
msgstr "FAQ"
#. js-lingui-explicit-id
msgid "没找到你的问题？欢迎邮件联系我们。"
msgstr "찾으시는 질문이 없나요? 언제든 이메일로 문의해 주세요."
#. js-lingui-explicit-id
msgid "隐界真的开源吗？"
msgstr "엔클레이브는 정말 오픈소스인가요?"
#. js-lingui-explicit-id
msgid "是。整个 monorepo（apps/app、apps/desktop、cloud-api、admin、site 等）都在 GitHub 上以 MIT 许可证开放，欢迎自部署、二次开发、商用。"
msgstr "네. 모든 monorepo (apps/app, apps/desktop, cloud-api, admin, site 등)가 MIT 라이선스로 GitHub 에 공개되어 있으며, 자체 호스팅 / 포크 / 상용화 모두 환영합니다."
#. js-lingui-explicit-id
msgid "我的数据保存在哪里？"
msgstr "내 데이터는 어디에 저장되나요?"
#. js-lingui-explicit-id
msgid "保存在你自己部署的实例里。隐界采用一人一世界的独立实例架构，没有中心化的数据后台，没有跨用户的数据合并；你拥有数据所有权。"
msgstr "직접 배포한 인스턴스에 저장됩니다. 엔클레이브는 한 사람당 하나의 인스턴스 구조로 운영되며, 중앙 데이터 백엔드도 사용자 간 데이터 병합도 없습니다. 데이터 소유권은 전적으로 사용자에게 있습니다."
#. js-lingui-explicit-id
msgid "用什么模型？能换模型吗？"
msgstr "어떤 모델을 지원하나요? 교체할 수 있나요?"
#. js-lingui-explicit-id
msgid "默认与多家主流模型供应商兼容（OpenAI 兼容协议），可在订阅页或自部署配置里切换；本地模型同样支持，只要服务能开 OpenAI 兼容的 HTTP 接口。"
msgstr "기본적으로 OpenAI 호환 프로토콜을 통해 주요 모델 제공자를 지원하며, 구독 화면 혹은 자체 호스팅 설정에서 전환할 수 있습니다. OpenAI 호환 HTTP 엔드포인트를 제공하면 로컬 모델도 그대로 사용할 수 있습니다."
#. js-lingui-explicit-id
msgid "可以离线使用吗？"
msgstr "오프라인 사용이 가능한가요?"
#. js-lingui-explicit-id
msgid "本地客户端（Tauri 桌面壳、Capacitor 移动壳）可离线浏览历史；AI 对话需要联网到模型服务（无论你是连云端还是本地模型）。"
msgstr "로컬 클라이언트(Tauri 데스크톱, Capacitor 모바일)는 오프라인에서도 기록을 볼 수 있습니다. AI 대화는 클라우드든 로컬이든 모델 서비스와의 통신이 필요합니다."
#. js-lingui-explicit-id
msgid "需要付费吗？"
msgstr "유료인가요?"
#. js-lingui-explicit-id
msgid "自部署完全免费。如果选择官方托管的云服务，按使用量付费——账单与你接入的模型供应商绑定，没有中间溢价。"
msgstr "자체 호스팅은 완전 무료입니다. 매니지드 클라우드를 선택하시면 사용량 기반으로 청구되며, 연결한 모델 제공자에게 직접 결제되고 중간 마진은 없습니다."
#. js-lingui-explicit-id
msgid "支持中英日韩之外的语言吗？"
msgstr "중·영·일·한 외 다른 언어도 지원하나요?"
#. js-lingui-explicit-id
msgid "界面目前支持简中 / English / 日本語 / 한국어。AI 角色对话本身不限语种，跟着模型能力走。"
msgstr "UI 는 현재 zh-CN / English / 日本語 / 한국어 를 지원합니다. AI 대화 자체는 언어에 구애받지 않으며, 모델의 역량을 따릅니다."
#. js-lingui-explicit-id
msgid "挑一种最顺手的方式开始用隐界"
msgstr "당신에게 가장 잘 맞는 방식으로 엔클레이브를 시작해 보세요"
#. js-lingui-explicit-id
msgid "桌面端原生封装、网页版即开即用，自部署提供完整自主权。移动端与小程序在路上。"
msgstr "네이티브 데스크톱 빌드, 즉시 사용 가능한 웹 버전, 자체 호스팅을 통한 완전한 자율성. 모바일 앱과 WeChat 미니 프로그램은 준비 중입니다."
#. js-lingui-explicit-id
msgid "敬请期待"
msgstr "출시 예정"
#. js-lingui-explicit-id
msgid "Windows 桌面端"
msgstr "Windows 데스크톱"
#. js-lingui-explicit-id
msgid "Tauri 原生封装，附带托盘和锁屏"
msgstr "Tauri 네이티브 빌드, 트레이와 잠금 화면 포함"
#. js-lingui-explicit-id
msgid "前往 GitHub Releases"
msgstr "GitHub Releases 열기"
