# Default provider for the instance
DEEPSEEK_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
# For image reading on OpenAI-compatible gateways, switch to a vision-capable model such as gpt-4.1.
AI_MODEL=deepseek-chat

# Server
ADMIN_SECRET=
# Required for wiki auth (register/login). Use a long random string in production.
JWT_SECRET=yinjie-dev-secret
PORT=3000
# Relative paths are resolved from the repository root.
DATABASE_PATH=./data/database.sqlite

# Remote deployment
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5181,http://localhost:5182,http://localhost:5184,http://localhost:5173,http://127.0.0.1:5180,http://127.0.0.1:5181,http://127.0.0.1:5182,http://127.0.0.1:5184,http://127.0.0.1:5173
PUBLIC_API_BASE_URL=http://localhost:3000

# Encrypts per-owner custom API keys on the server.
# Use a long random string in production.
USER_API_KEY_ENCRYPTION_SECRET=

# Email verification (login/register via email code).
# 留空 SMTP_HOST 时验证码会打印到服务端日志（dev mock 模式），凭证就绪后填入即真实发送。
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=隐界 Yinjie
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60
EMAIL_CODE_RATE_LIMIT_WINDOW_SECONDS=3600
EMAIL_CODE_MAX_PER_WINDOW=5
