# Default provider for the instance
DEEPSEEK_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
# For image reading on OpenAI-compatible gateways, switch to a vision-capable model such as gpt-4.1.
AI_MODEL=deepseek-chat

# MiniMax Token Plan (NPC video/music generation in 视频号 / 朋友圈)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com
# minimax /v1/lyrics_generation 开关；默认 true（tokenplan 已覆盖该端点）。
# 端点配额或调用失败时，会自动退回 AiOrchestrator (MiniMax-M2.7 → n1n) 兜底；
# 若端点持续异常想紧急关闭，把这里改成 false 即可，行为退化为只走 LLM 兜底。
MINIMAX_LYRICS_ENABLED=true

# Server
ADMIN_SECRET=
# Required for wiki auth (register/login). Use a long random string in production.
JWT_SECRET=yinjie-dev-secret
PORT=3000
# Relative paths are resolved from the repository root.
DATABASE_PATH=./data/database.sqlite

# Remote deployment
CORS_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5181,http://localhost:5182,http://localhost:5184,http://localhost:5173,http://127.0.0.1:5180,http://127.0.0.1:5181,http://127.0.0.1:5182,http://127.0.0.1:5184,http://127.0.0.1:5173
PUBLIC_API_BASE_URL=http://localhost:3000

# Encrypts per-owner custom API keys on the server.
# Use a long random string in production.
USER_API_KEY_ENCRYPTION_SECRET=

# Email verification (login/register via email code).
# 留空 SMTP_HOST 时验证码会打印到服务端日志（dev mock 模式），凭证就绪后填入即真实发送。
#
# Wiki 邮件按收件人邮箱域名分流（与 cloud-api 一致）：
#   - 海外域名（gmail/outlook/yahoo/icloud/proton/yandex/naver/kakao 等 31 个）→ 走 SMTP_OVERSEAS_*
#   - 其他（qq/163/126/foxmail/企业邮箱 等）→ 走默认 SMTP_*
# 海外通道未配置时自动回落到默认通道，并打 warn 日志。
# 注：env 里写 KEY=（空字符串）等同于未配置，会触发 fallback 默认值；要清空就直接注释掉。
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_PROXY=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=隐界 Yinjie

# 海外邮箱通道（可选）。未配置则海外邮件回落到上面的默认通道。
# 典型组合：默认通道用阿里云 DirectMail（国内投递率好），海外通道用 Gmail/SES（海外投递率好）。
# from 地址独立配置，避免阿里云 DirectMail 因 envelope-from 不在已验证发信地址清单中被 5.7.0 拒收。
SMTP_OVERSEAS_HOST=
SMTP_OVERSEAS_PORT=465
SMTP_OVERSEAS_SECURE=true
SMTP_OVERSEAS_USER=
SMTP_OVERSEAS_PASS=
SMTP_OVERSEAS_PROXY=
MAIL_OVERSEAS_FROM_ADDRESS=
MAIL_OVERSEAS_FROM_NAME=

EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60
EMAIL_CODE_RATE_LIMIT_WINDOW_SECONDS=3600
EMAIL_CODE_MAX_PER_WINDOW=5
