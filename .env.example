YINJIE_PROVIDER_ENDPOINT=https://api.n1n.ai/v1/chat/completions
YINJIE_PROVIDER_MODEL=deepseek-chat
YINJIE_PROVIDER_API_KEY=
YINJIE_PROVIDER_MODE=cloud
YINJIE_PROVIDER_API_STYLE=openai-chat-completions

# MiniMax Token Plan（NPC 视频/音乐生成、image-01、TTS HD）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com

# MiniMax Token Plan key 池 — cloud-api 按 worldId 稳定 hash 分配。多个 key
# 用英文逗号分隔，单 key 时可以只填上面的 MINIMAX_API_KEY。分配逻辑见
# apps/cloud-api/src/orchestration/local-process-compute-provider.service.ts
MINIMAX_API_KEYS=

# minimax /v1/lyrics_generation 开关；默认 true（tokenplan 已覆盖该端点）。
# 端点配额或调用失败时，会自动退回 AiOrchestrator (MiniMax-M2.7 → n1n) 兜底；
# 若端点持续异常想紧急关闭，把这里改成 false 即可，行为退化为只走 LLM 兜底。
MINIMAX_LYRICS_ENABLED=true
